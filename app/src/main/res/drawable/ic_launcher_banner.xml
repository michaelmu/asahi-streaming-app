<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/asahi_bg" />
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/asahi_panel_elevated" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="@color/asahi_stroke" />
        </shape>
    </item>
    <item android:left="60dp" android:top="10dp" android:right="60dp" android:bottom="10dp">
        <bitmap
            android:gravity="center"
            android:antialias="true"
            android:filter="true"
            android:src="@drawable/asahi_brand_mark" />
    </item>
</layer-list>
