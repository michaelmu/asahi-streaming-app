<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <solid android:color="@color/asahi_panel_soft" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="@color/asahi_accent" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/asahi_panel_soft" />
            <corners android:radius="999dp" />
            <stroke
                android:width="2dp"
                android:color="@color/asahi_focus" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/asahi_panel" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="@color/asahi_stroke" />
        </shape>
    </item>
</selector>